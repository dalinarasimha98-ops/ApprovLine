{
  "name": "approvline",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/production-build.mjs",
    "start": "next start",
    "lint": "eslint .",
    "check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "seed:demo": "tsx scripts/seed-demo.ts",
    "test:classifier-corpus": "node scripts/validate-classifier-corpus.mjs",
    "test:ingestion": "tsx tests/ingestion-pipeline.test.ts",
    "test:slack": "tsx tests/slack-integration.test.ts",
    "test:gmail": "tsx tests/gmail-integration.test.ts",
    "test:teams": "tsx tests/teams-integration.test.ts",
    "test:founder": "node --import tsx tests/founder-hardening.test.ts",
    "test:reliability": "node --import tsx tests/reliability-hardening.test.ts",
    "test:tenant-isolation": "node --import tsx tests/tenant-isolation.test.ts",
    "test:certification": "node --import tsx tests/production-certification.test.ts",
    "test:production-hardening": "node --import tsx tests/production-hardening.test.ts",
    "test:manual-approvals": "node --import tsx tests/manual-approvals.test.ts",
    "test:evidence": "node --import tsx tests/evidence-platform.test.ts",
    "test:e2e:approvals": "playwright test tests/e2e/approval-timeline.spec.ts",
    "readiness": "tsx scripts/readiness.ts",
    "gmail:sync": "tsx scripts/gmail-sync.ts",
    "worker": "tsx services/queue/worker.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.32.0",
    "@prisma/client": "^6.10.1",
    "@sentry/nextjs": "^10.66.0",
    "bullmq": "^5.56.0",
    "ioredis": "^5.6.1",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.12.0",
    "next": "^15.3.4",
    "openai": "^5.8.2",
    "pdf-parse": "^2.4.5",
    "prisma": "^6.10.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.0.7",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.1",
    "eslint-config-next": "^15.5.19",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "overrides": {
    "postcss": "$postcss"
  },
  "engines": {
    "node": "20.x"
  }
}
