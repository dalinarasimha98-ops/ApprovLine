generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
  COMPLIANCE_OFFICER
}

enum PlatformRole {
  SUPER_ADMIN
  FOUNDER_ADMIN
  SUPPORT_ADMIN
}

enum CustomerPlanTier {
  FREE_TRIAL
  STARTER
  GROWTH
  ENTERPRISE
}

enum CustomerAccountStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CHURNED
}

enum CustomerIntegrationConnectionState {
  ACCESS_ENABLED
  NOT_ENABLED
  CONNECTED
  DISCONNECTED
  NEEDS_REAUTH
  ERROR
}

enum CustomerHealthStatus {
  HEALTHY
  NEEDS_ATTENTION
  AT_RISK
  CRITICAL
}

enum FounderManagedUserStatus {
  INVITED
  ACTIVE
  SUSPENDED
  EXPIRED
  REVOKED
  REMOVED
}

enum FounderManagedUserRole {
  ORG_ADMIN
  COMPLIANCE
  LEGAL
  FINANCE
  PROCUREMENT
  ENGINEERING
  VIEWER
}

enum IntegrationProvider {
  SLACK
  GMAIL
  OUTLOOK
  MICROSOFT_TEAMS
  JIRA
  SERVICENOW
  ZOOM
}

enum IntegrationStatus {
  CONNECTED
  DISCONNECTED
  NEEDS_REAUTH
  ERROR
  SYNCING
}

enum ApprovalType {
  EXPLICIT
  IMPLICIT
  CONDITIONAL
  REJECTION
  ESCALATION
  NOT_APPROVAL
}

enum ApprovalStatus {
  APPROVED
  PENDING_REVIEW
  REJECTED
  NOT_A_DECISION
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum InvestigationStatus {
  OPEN
  CLOSED
}

model Organization {
  id                String             @id @default(cuid())
  clerkOrgId        String?            @unique
  name              String
  slug              String             @unique
  departments       String[]
  approvalCategories String[]
  onboardedAt       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  users             User[]
  teams             Team[]
  integrations      Integration[]
  approvalRecords   ApprovalRecord[]
  auditLogs         AuditLog[]
  classifierResults ClassifierResult[]
  subscriptions     Subscription[]
  events            Event[]
  messageSources    MessageSource[]
  playbookDocuments PlaybookDocument[]
  playbookChunks    PlaybookChunk[]
  playbookRules     PlaybookRule[]
  playbookQueries   PlaybookQuery[]
  complianceEvaluations ApprovalComplianceEvaluation[]
  investigations    InvestigationCase[]
  investigationNotes InvestigationNote[]
  featureFlags      FeatureFlag[]
  pilotInvites      PilotInvite[]
  pilotFeedback     PilotFeedback[]
  pilotActivityLogs PilotActivityLog[]
  customerAccount   CustomerAccount?
  customerWorkspace CustomerWorkspace?
  founderManagedUsers FounderManagedUser[]
}

model User {
  id             String         @id @default(cuid())
  organizationId String
  clerkUserId    String         @unique
  email          String
  name           String?
  role           Role           @default(EMPLOYEE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  teams          TeamMember[]
  approvals      ApprovalRecord[] @relation("ApprovalApprover")
  auditLogs      AuditLog[]
  investigationNotes InvestigationNote[]
  pilotInvites    PilotInvite[] @relation("PilotInviteInviter")
  pilotFeedback   PilotFeedback[]
  pilotActivityLogs PilotActivityLog[]
  featureFlagsUpdated FeatureFlag[] @relation("FeatureFlagUpdater")

  @@index([organizationId, role])
  @@index([email])
}

model Team {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  department     String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members        TeamMember[]

  @@unique([organizationId, name])
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  createdAt DateTime @default(now())
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model Integration {
  id              String             @id @default(cuid())
  organizationId  String
  provider        IntegrationProvider
  status          IntegrationStatus  @default(CONNECTED)
  externalAccount String?
  scopes          String[]
  encryptedTokens Json?
  metadata        Json?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messageSources  MessageSource[]
  events          Event[]

  @@unique([organizationId, provider, externalAccount])
  @@index([organizationId, provider])
}

model MessageSource {
  id             String              @id @default(cuid())
  organizationId String
  integrationId  String?
  provider       IntegrationProvider
  externalId     String?
  channel        String?
  sender         String?
  senderEmail    String?
  rawPayload     Json?
  receivedAt     DateTime            @default(now())
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  integration    Integration?        @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  approvalRecords ApprovalRecord[]
  classifierResults ClassifierResult[]

  @@index([organizationId, provider, receivedAt])
  @@index([externalId])
}

model ApprovalRecord {
  id                 String             @id @default(cuid())
  organizationId     String
  messageSourceId    String?
  approverUserId     String?
  approverName       String?
  approverEmail      String?
  subject            String
  department         String?
  category           String?
  approvalType       ApprovalType
  status             ApprovalStatus
  confidence         Int
  riskLevel          String?
  businessImpact     String?
  reasoning          String
  conditions         String?
  sourcePlatform     String?
  sourceLink         String?
  evidenceSnippet    String?
  approvalTimestamp  DateTime?
  occurredAt         DateTime           @default(now())
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messageSource      MessageSource?     @relation(fields: [messageSourceId], references: [id], onDelete: SetNull)
  approverUser       User?              @relation("ApprovalApprover", fields: [approverUserId], references: [id], onDelete: SetNull)
  classifierResults  ClassifierResult[]
  auditLogs          AuditLog[]
  investigations     InvestigationApproval[]
  complianceEvaluations ApprovalComplianceEvaluation[]

  @@index([organizationId, occurredAt])
  @@index([organizationId, department])
  @@index([organizationId, approverName])
  @@index([organizationId, approverEmail])
  @@index([organizationId, category])
  @@index([organizationId, riskLevel])
  @@index([organizationId, sourcePlatform])
  @@index([organizationId, approvalType])
  @@index([organizationId, status, occurredAt])
}

model ClassifierResult {
  id                String          @id @default(cuid())
  organizationId    String
  messageSourceId   String?
  approvalRecordId  String?
  model             String
  promptVersion     String
  inputHash         String
  approvalDetected  Boolean
  approvalType      ApprovalType
  confidence        Int
  normalizedJson    Json
  latencyMs         Int?
  createdAt         DateTime        @default(now())
  organization      Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messageSource     MessageSource?  @relation(fields: [messageSourceId], references: [id], onDelete: SetNull)
  approvalRecord    ApprovalRecord? @relation(fields: [approvalRecordId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([inputHash])
}

model AuditLog {
  id               String          @id @default(cuid())
  organizationId   String
  actorUserId      String?
  approvalRecordId String?
  action           String
  ipAddress        String?
  userAgent        String?
  metadata         Json?
  createdAt        DateTime        @default(now())
  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorUser        User?           @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  approvalRecord   ApprovalRecord? @relation(fields: [approvalRecordId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([action])
  @@index([organizationId, actorUserId, createdAt])
}

model Subscription {
  id             String             @id @default(cuid())
  organizationId String
  stripeCustomerId String?
  stripeSubscriptionId String?
  plan           String
  status         SubscriptionStatus
  seats          Int                @default(1)
  currentPeriodEnd DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
}

model Event {
  id             String       @id @default(cuid())
  organizationId String
  integrationId  String?
  type           String
  payload        Json
  processedAt    DateTime?
  failedAt       DateTime?
  failureReason  String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  integration    Integration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  @@index([organizationId, type, createdAt])
}

enum PlaybookStatus {
  UPLOADED
  INDEXING
  READY
  ERROR
}

model PlaybookDocument {
  id             String          @id @default(cuid())
  organizationId String
  ownerUserId    String?
  name           String
  fileType       String
  status         PlaybookStatus  @default(UPLOADED)
  contentHash    String
  metadata       Json?
  uploadedAt     DateTime        @default(now())
  lastIndexedAt  DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  chunks         PlaybookChunk[]
  rules          PlaybookRule[]

  @@index([organizationId, status, uploadedAt])
  @@index([organizationId, contentHash])
}

model PlaybookChunk {
  id             String           @id @default(cuid())
  organizationId String
  documentId     String
  chunkIndex     Int
  content        String
  sectionTitle   String?
  tokenEstimate  Int
  embedding      Json
  metadata       Json?
  createdAt      DateTime         @default(now())
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  document       PlaybookDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex])
  @@index([organizationId, documentId])
}

model PlaybookRule {
  id                  String       @id @default(cuid())
  organizationId      String
  documentId          String
  category            String
  title               String
  description         String
  requiredApprovers   String[]
  requiredDepartments String[]
  escalationChain     String[]
  spendingLimit       Int?
  riskTriggers        String[]
  evidenceRequired    String[]
  severity            String       @default("medium")
  sourceSection       String?
  sourceExcerpt       String
  createdAt           DateTime     @default(now())
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  document            PlaybookDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  evaluations         ApprovalComplianceEvaluation[]

  @@index([organizationId, category])
  @@index([organizationId, severity])
  @@index([organizationId, documentId])
}

model ApprovalComplianceEvaluation {
  id                   String          @id @default(cuid())
  organizationId       String
  approvalRecordId     String
  ruleId               String?
  status               String
  score                Int
  severity             String
  missingApprovers     String[]
  missingDepartments   String[]
  missingEscalationSteps String[]
  missingEvidence      String[]
  triggeredRule        String?
  explanation          String
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  organization         Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  approvalRecord       ApprovalRecord  @relation(fields: [approvalRecordId], references: [id], onDelete: Cascade)
  rule                 PlaybookRule?   @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  @@index([organizationId, status, createdAt])
  @@index([organizationId, severity])
  @@index([approvalRecordId])
  @@index([ruleId])
}

model PlaybookQuery {
  id             String       @id @default(cuid())
  organizationId String
  actorUserId    String?
  question       String
  answer         Json
  sourceChunkIds String[]
  confidence     Int
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
}

model InvestigationCase {
  id             String                  @id @default(cuid())
  organizationId String
  title          String
  status         InvestigationStatus     @default(OPEN)
  department     String?
  riskLevel      String?
  summary        String?
  dateRangeStart DateTime?
  dateRangeEnd   DateTime?
  metadata       Json?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  approvals      InvestigationApproval[]
  notes          InvestigationNote[]

  @@index([organizationId, status, createdAt])
  @@index([organizationId, department])
  @@index([organizationId, riskLevel])
}

model InvestigationApproval {
  id              String            @id @default(cuid())
  investigationId String
  approvalRecordId String
  createdAt       DateTime          @default(now())
  investigation   InvestigationCase @relation(fields: [investigationId], references: [id], onDelete: Cascade)
  approvalRecord  ApprovalRecord    @relation(fields: [approvalRecordId], references: [id], onDelete: Cascade)

  @@unique([investigationId, approvalRecordId])
  @@index([approvalRecordId])
}

model InvestigationNote {
  id              String            @id @default(cuid())
  organizationId  String
  investigationId String
  authorUserId    String?
  body            String
  createdAt       DateTime          @default(now())
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  investigation   InvestigationCase @relation(fields: [investigationId], references: [id], onDelete: Cascade)
  authorUser      User?             @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, investigationId, createdAt])
}

model FeatureFlag {
  id              String       @id @default(cuid())
  organizationId  String
  key             String
  enabled         Boolean      @default(false)
  description     String?
  updatedByUserId String?
  metadata        Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  updatedByUser   User?        @relation("FeatureFlagUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([organizationId, key])
  @@index([organizationId, enabled])
}

model PilotInvite {
  id              String       @id @default(cuid())
  organizationId  String
  inviterUserId   String?
  email           String
  role            Role         @default(EMPLOYEE)
  status          String       @default("pending")
  invitedAt       DateTime     @default(now())
  acceptedAt      DateTime?
  metadata        Json?
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviterUser     User?        @relation("PilotInviteInviter", fields: [inviterUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, status, invitedAt])
  @@index([email])
}

model PilotFeedback {
  id             String       @id @default(cuid())
  organizationId String
  userId         String?
  type           String
  title          String
  body           String
  pageUrl        String?
  screenshot     Json?
  status         String       @default("open")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, status, createdAt])
  @@index([organizationId, type])
}

model PilotActivityLog {
  id             String       @id @default(cuid())
  organizationId String
  actorUserId    String?
  action         String
  entityType     String?
  entityId       String?
  metadata       Json?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorUser      User?        @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([organizationId, action])
}

model PlatformAdmin {
  id        String       @id @default(cuid())
  email     String       @unique
  role      PlatformRole @default(SUPPORT_ADMIN)
  active    Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([active, role])
}

model CustomerAccount {
  id                  String                @id @default(cuid())
  organizationId      String                @unique
  companyName         String
  domain              String                @unique
  industry            String?
  status              CustomerAccountStatus @default(TRIAL)
  planTier            CustomerPlanTier      @default(FREE_TRIAL)
  primaryAdminName    String?
  primaryAdminEmail   String
  dataRetentionDays   Int                   @default(365)
  internalNotes       String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  organization        Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace           CustomerWorkspace?
  seatAllocation      CustomerSeatAllocation?
  featureFlags        CustomerFeatureFlag[]
  integrationStatuses CustomerIntegrationStatus[]
  auditLogs           FounderAuditLog[]
  notes               CustomerNote[]
  health              CustomerHealth?
  managedUsers        FounderManagedUser[]

  @@index([status, planTier])
  @@index([companyName])
  @@index([createdAt])
}

model CustomerWorkspace {
  id                String          @id @default(cuid())
  customerAccountId String          @unique
  organizationId    String          @unique
  workspaceName     String
  workspaceSlug     String          @unique
  provisionedAt     DateTime        @default(now())
  metadata          Json?
  customerAccount   CustomerAccount @relation(fields: [customerAccountId], references: [id], onDelete: Cascade)
  organization      Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model CustomerPlan {
  id               String           @id @default(cuid())
  planTier         CustomerPlanTier  @unique
  name             String
  description      String?
  seatLimitDefault Int              @default(5)
  priceLabel       String?
  features         String[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model CustomerSeatAllocation {
  id                String          @id @default(cuid())
  customerAccountId String          @unique
  purchasedSeats    Int             @default(5)
  allocatedSeats    Int             @default(5)
  usedSeats         Int             @default(0)
  updatedAt         DateTime        @updatedAt
  customerAccount   CustomerAccount @relation(fields: [customerAccountId], references: [id], onDelete: Cascade)
}

model CustomerFeatureFlag {
  id                String          @id @default(cuid())
  customerAccountId String
  key               String
  enabled           Boolean         @default(false)
  category          String?
  updatedBy         String?
  updatedAt         DateTime        @updatedAt
  customerAccount   CustomerAccount @relation(fields: [customerAccountId], references: [id], onDelete: Cascade)

  @@unique([customerAccountId, key])
  @@index([key, enabled])
}

model CustomerIntegrationStatus {
  id                String                             @id @default(cuid())
  customerAccountId String
  provider          String
  accessEnabled     Boolean                            @default(false)
  connectionState   CustomerIntegrationConnectionState @default(NOT_ENABLED)
  lastSyncAt        DateTime?
  errorCount        Int                                @default(0)
  eventsProcessed   Int                                @default(0)
  metadata          Json?
  updatedAt         DateTime                           @updatedAt
  customerAccount   CustomerAccount                    @relation(fields: [customerAccountId], references: [id], onDelete: Cascade)

  @@unique([customerAccountId, provider])
  @@index([provider, connectionState])
}

model FounderAuditLog {
  id                String           @id @default(cuid())
  customerAccountId String?
  actorUserId       String?
  actorEmail        String?
  actorRole         String?
  action            String
  targetType        String
  targetId          String?
  metadata          Json?
  createdAt         DateTime         @default(now())
  customerAccount   CustomerAccount? @relation(fields: [customerAccountId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([actorEmail])
  @@index([customerAccountId, createdAt])
  @@index([action])
}

model CustomerNote {
  id                String          @id @default(cuid())
  customerAccountId String
  authorEmail       String?
  body              String
  pinned            Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  customerAccount   CustomerAccount @relation(fields: [customerAccountId], references: [id], onDelete: Cascade)

  @@index([customerAccountId, pinned, createdAt])
  @@index([customerAccountId, createdAt])
}

model CustomerHealth {
  id                    String               @id @default(cuid())
  customerAccountId     String               @unique
  status                CustomerHealthStatus @default(NEEDS_ATTENTION)
  score                 Int                  @default(50)
  lastLoginAt           DateTime?
  activeUsers           Int                  @default(0)
  approvalsProcessed    Int                  @default(0)
  integrationsConnected Int                  @default(0)
  playbookUsage         Int                  @default(0)
  copilotUsage          Int                  @default(0)
  updatedAt             DateTime             @updatedAt
  customerAccount       CustomerAccount      @relation(fields: [customerAccountId], references: [id], onDelete: Cascade)

  @@index([status, score])
}

model FounderManagedUser {
  id                String                   @id @default(cuid())
  customerAccountId String
  organizationId    String
  firstName         String
  lastName          String
  email             String
  role              FounderManagedUserRole   @default(VIEWER)
  status            FounderManagedUserStatus @default(INVITED)
  inviteToken       String?                  @unique
  invitedAt         DateTime                 @default(now())
  acceptedAt        DateTime?
  expiresAt         DateTime?
  revokedAt         DateTime?
  suspendedAt       DateTime?
  removedAt         DateTime?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  customerAccount   CustomerAccount          @relation(fields: [customerAccountId], references: [id], onDelete: Cascade)
  organization      Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([customerAccountId, email])
  @@index([organizationId, status])
  @@index([customerAccountId, status])
  @@index([customerAccountId, role])
  @@index([email])
}
