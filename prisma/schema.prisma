generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
  COMPLIANCE_OFFICER
}

enum IntegrationProvider {
  SLACK
  GMAIL
  MICROSOFT_TEAMS
  ZOOM
}

enum IntegrationStatus {
  CONNECTED
  DISCONNECTED
  NEEDS_REAUTH
  ERROR
  SYNCING
}

enum ApprovalType {
  EXPLICIT
  IMPLICIT
  CONDITIONAL
  REJECTION
  ESCALATION
  NOT_APPROVAL
}

enum ApprovalStatus {
  APPROVED
  PENDING_REVIEW
  REJECTED
  NOT_A_DECISION
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum InvestigationStatus {
  OPEN
  CLOSED
}

model Organization {
  id                String             @id @default(cuid())
  clerkOrgId        String?            @unique
  name              String
  slug              String             @unique
  departments       String[]
  approvalCategories String[]
  onboardedAt       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  users             User[]
  teams             Team[]
  integrations      Integration[]
  approvalRecords   ApprovalRecord[]
  auditLogs         AuditLog[]
  classifierResults ClassifierResult[]
  subscriptions     Subscription[]
  events            Event[]
  messageSources    MessageSource[]
  playbookDocuments PlaybookDocument[]
  playbookChunks    PlaybookChunk[]
  playbookQueries   PlaybookQuery[]
  investigations    InvestigationCase[]
  investigationNotes InvestigationNote[]
}

model User {
  id             String         @id @default(cuid())
  organizationId String
  clerkUserId    String         @unique
  email          String
  name           String?
  role           Role           @default(EMPLOYEE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  teams          TeamMember[]
  approvals      ApprovalRecord[] @relation("ApprovalApprover")
  auditLogs      AuditLog[]
  investigationNotes InvestigationNote[]

  @@index([organizationId, role])
  @@index([email])
}

model Team {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  department     String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members        TeamMember[]

  @@unique([organizationId, name])
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  createdAt DateTime @default(now())
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model Integration {
  id              String             @id @default(cuid())
  organizationId  String
  provider        IntegrationProvider
  status          IntegrationStatus  @default(CONNECTED)
  externalAccount String?
  scopes          String[]
  encryptedTokens Json?
  metadata        Json?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messageSources  MessageSource[]
  events          Event[]

  @@unique([organizationId, provider, externalAccount])
  @@index([organizationId, provider])
}

model MessageSource {
  id             String              @id @default(cuid())
  organizationId String
  integrationId  String?
  provider       IntegrationProvider
  externalId     String?
  channel        String?
  sender         String?
  senderEmail    String?
  rawPayload     Json?
  receivedAt     DateTime            @default(now())
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  integration    Integration?        @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  approvalRecords ApprovalRecord[]
  classifierResults ClassifierResult[]

  @@index([organizationId, provider, receivedAt])
  @@index([externalId])
}

model ApprovalRecord {
  id                 String             @id @default(cuid())
  organizationId     String
  messageSourceId    String?
  approverUserId     String?
  approverName       String?
  approverEmail      String?
  subject            String
  department         String?
  category           String?
  approvalType       ApprovalType
  status             ApprovalStatus
  confidence         Int
  riskLevel          String?
  businessImpact     String?
  reasoning          String
  conditions         String?
  sourcePlatform     String?
  sourceLink         String?
  evidenceSnippet    String?
  approvalTimestamp  DateTime?
  occurredAt         DateTime           @default(now())
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messageSource      MessageSource?     @relation(fields: [messageSourceId], references: [id], onDelete: SetNull)
  approverUser       User?              @relation("ApprovalApprover", fields: [approverUserId], references: [id], onDelete: SetNull)
  classifierResults  ClassifierResult[]
  auditLogs          AuditLog[]
  investigations     InvestigationApproval[]

  @@index([organizationId, occurredAt])
  @@index([organizationId, department])
  @@index([organizationId, approverName])
  @@index([organizationId, approverEmail])
  @@index([organizationId, category])
  @@index([organizationId, riskLevel])
  @@index([organizationId, sourcePlatform])
  @@index([organizationId, approvalType])
  @@index([organizationId, status, occurredAt])
}

model ClassifierResult {
  id                String          @id @default(cuid())
  organizationId    String
  messageSourceId   String?
  approvalRecordId  String?
  model             String
  promptVersion     String
  inputHash         String
  approvalDetected  Boolean
  approvalType      ApprovalType
  confidence        Int
  normalizedJson    Json
  latencyMs         Int?
  createdAt         DateTime        @default(now())
  organization      Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messageSource     MessageSource?  @relation(fields: [messageSourceId], references: [id], onDelete: SetNull)
  approvalRecord    ApprovalRecord? @relation(fields: [approvalRecordId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([inputHash])
}

model AuditLog {
  id               String          @id @default(cuid())
  organizationId   String
  actorUserId      String?
  approvalRecordId String?
  action           String
  ipAddress        String?
  userAgent        String?
  metadata         Json?
  createdAt        DateTime        @default(now())
  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorUser        User?           @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  approvalRecord   ApprovalRecord? @relation(fields: [approvalRecordId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([action])
  @@index([organizationId, actorUserId, createdAt])
}

model Subscription {
  id             String             @id @default(cuid())
  organizationId String
  stripeCustomerId String?
  stripeSubscriptionId String?
  plan           String
  status         SubscriptionStatus
  seats          Int                @default(1)
  currentPeriodEnd DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
}

model Event {
  id             String       @id @default(cuid())
  organizationId String
  integrationId  String?
  type           String
  payload        Json
  processedAt    DateTime?
  failedAt       DateTime?
  failureReason  String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  integration    Integration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  @@index([organizationId, type, createdAt])
}

enum PlaybookStatus {
  UPLOADED
  INDEXING
  READY
  ERROR
}

model PlaybookDocument {
  id             String          @id @default(cuid())
  organizationId String
  ownerUserId    String?
  name           String
  fileType       String
  status         PlaybookStatus  @default(UPLOADED)
  contentHash    String
  metadata       Json?
  uploadedAt     DateTime        @default(now())
  lastIndexedAt  DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  chunks         PlaybookChunk[]

  @@index([organizationId, status, uploadedAt])
  @@index([organizationId, contentHash])
}

model PlaybookChunk {
  id             String           @id @default(cuid())
  organizationId String
  documentId     String
  chunkIndex     Int
  content        String
  sectionTitle   String?
  tokenEstimate  Int
  embedding      Json
  metadata       Json?
  createdAt      DateTime         @default(now())
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  document       PlaybookDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex])
  @@index([organizationId, documentId])
}

model PlaybookQuery {
  id             String       @id @default(cuid())
  organizationId String
  actorUserId    String?
  question       String
  answer         Json
  sourceChunkIds String[]
  confidence     Int
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
}

model InvestigationCase {
  id             String                  @id @default(cuid())
  organizationId String
  title          String
  status         InvestigationStatus     @default(OPEN)
  department     String?
  riskLevel      String?
  summary        String?
  dateRangeStart DateTime?
  dateRangeEnd   DateTime?
  metadata       Json?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  approvals      InvestigationApproval[]
  notes          InvestigationNote[]

  @@index([organizationId, status, createdAt])
  @@index([organizationId, department])
  @@index([organizationId, riskLevel])
}

model InvestigationApproval {
  id              String            @id @default(cuid())
  investigationId String
  approvalRecordId String
  createdAt       DateTime          @default(now())
  investigation   InvestigationCase @relation(fields: [investigationId], references: [id], onDelete: Cascade)
  approvalRecord  ApprovalRecord    @relation(fields: [approvalRecordId], references: [id], onDelete: Cascade)

  @@unique([investigationId, approvalRecordId])
  @@index([approvalRecordId])
}

model InvestigationNote {
  id              String            @id @default(cuid())
  organizationId  String
  investigationId String
  authorUserId    String?
  body            String
  createdAt       DateTime          @default(now())
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  investigation   InvestigationCase @relation(fields: [investigationId], references: [id], onDelete: Cascade)
  authorUser      User?             @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, investigationId, createdAt])
}
